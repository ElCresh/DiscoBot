# DiscoBot Configuration
# Copy this file to .env and fill in the values.

# Verbose logging (livello INFO). Override da CLI con --debug.
DISCOBOT_DEBUG=false
DISCOBOT_HOST=0.0.0.0
DISCOBOT_PORT=8000
DISCOBOT_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Spotify integration (optional — leave empty to disable)
# Create an app at https://developer.spotify.com/dashboard to get these.
DISCOBOT_SPOTIFY_CLIENT_ID=
DISCOBOT_SPOTIFY_CLIENT_SECRET=
# Path where librespot stores its session credentials (written by
# `python main.py --spotify-login`). Required for direct Spotify playback.
DISCOBOT_SPOTIFY_CREDENTIALS_FILE=.spotify_credentials.json

# Presentation window (native fullscreen kiosk)
# Index of the monitor on which the presentation appears. 0 = primary.
DISCOBOT_PRESENTATION_MONITOR=0
